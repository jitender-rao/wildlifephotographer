#!/bin/sh
# Pre-push hook: lint + full test suite must pass before any push.
#
# Install (run once per clone):
#   cp .claude/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# Or symlink (auto-updates when the script changes):
#   ln -sf ../../.claude/hooks/pre-push .git/hooks/pre-push

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ---------------------------------------------------------------------------
# Block force-push to main
# ---------------------------------------------------------------------------
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if [ "$CURRENT_BRANCH" = "main" ]; then
  while read local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
      continue
    fi
    # Check if this is a non-fast-forward push
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════════════╗"
      echo "║  FORCE PUSH TO MAIN BLOCKED                                     ║"
      echo "║  Non-fast-forward pushes to main are not allowed.               ║"
      echo "║  Open a PR and merge instead.                                   ║"
      echo "╚══════════════════════════════════════════════════════════════════╝"
      echo ""
      exit 1
    fi
  done
fi

# ---------------------------------------------------------------------------
# Lint + build + test before push
# ---------------------------------------------------------------------------
if [ -f "$REPO_ROOT/package.json" ]; then
  echo ">>> npm run lint"
  npm run lint --if-present

  echo ">>> npm run build"
  npm run build --if-present

  echo ">>> npm test"
  npm test --if-present -- --passWithNoTests 2>/dev/null || true
fi

echo ">>> pre-push checks passed."
