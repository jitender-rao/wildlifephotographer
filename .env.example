# ── Copy this file to .env.local and fill in real values ──
# Never commit .env.local

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=           # Editor role — server-only, never NEXT_PUBLIC
SANITY_WEBHOOK_SECRET=      # Random string; set same value in Sanity webhook config

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (India only)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Auth (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=            # Generate: openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email — Resend (transactional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@wildwanderings.in
SUDIIP_CONTACT_EMAIL=sudiip@wildwanderings.in

# Newsletter — ConvertKit
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Cloudinary (image CDN)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=  # Create an unsigned preset in Cloudinary dashboard

# Mapbox (tour location maps)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Analytics
NEXT_PUBLIC_META_PIXEL_ID=

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX  # Sudiip's number with country code

# Studio protection
STUDIO_PREVIEW_SECRET=      # Random string for /studio access

# Rate limiting (Upstash Redis) — for /api/contact
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
